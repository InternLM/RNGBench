# Copy to .env and fill in the keys for whichever endpoints you use.
# A preset only needs the key its endpoint uses — you do NOT need all of them.

# ── Default OpenAI-compatible endpoint ──
# Used by the gpt-5.4 presets, and as the fallback when a preset omits api_base.
# For a local vLLM / lmdeploy / Ollama server, point the base at it and use any
# placeholder key (e.g. EMPTY).
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_KEY=sk-xxx

# ── Google Gemini (native API; gemini-3.1-pro presets) ──
# GEMINI_API_KEY=xxx

# ── Volcengine Ark / Doubao Seed (seed-2.0 presets; base path is /api/v3) ──
# ARK_API_KEY=xxx

# ── Reproducible sampler seed (presets opt in via sample_seed_env) ──
NON_MARKOV_SAMPLE_SEED=42
